# BYOLLM Provider Configuration
# Options: openai, groq, openrouter, mistral, ollama, custom
LLM_PROVIDER=mistral

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=

# Model Configuration
MODEL_NAME=mistral-small-latest

# Groq API Key Configuration
# The agent supports a primary → secondary → tertiary fallback chain for Groq.
# Fallback is triggered ONLY on HTTP 429 (rate-limit) errors — not on other errors.
# GROQ_API_KEY_PRIMARY is required when LLM_PROVIDER=groq.
# GROQ_API_KEY_SECONDARY and GROQ_API_KEY_TERTIARY are optional;
#   they are only used if the preceding key hits a 429 rate-limit.
# Only the key slot name (primary/secondary/tertiary) is ever logged — never the key value.
# GROQ_API_KEY is a legacy alias for GROQ_API_KEY_PRIMARY for backward compatibility.
GROQ_API_KEY_PRIMARY=your_primary_groq_api_key_here
GROQ_API_KEY_SECONDARY=your_secondary_groq_api_key_here
GROQ_API_KEY_TERTIARY=your_tertiary_groq_api_key_here

# OpenAI-compatible provider keys
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Indian Stock AI Agent

# Mistral API Key Configuration
# The agent supports a primary → secondary → tertiary fallback chain for Mistral.
# Fallback is triggered ONLY on HTTP 429 (rate-limit) errors — not on other errors.
# MISTRAL_API_KEY_PRIMARY is required when LLM_PROVIDER=mistral.
# MISTRAL_API_KEY_SECONDARY and MISTRAL_API_KEY_TERTIARY are optional;
#   they are only used if the preceding key hits a 429 rate-limit.
# Only the key slot name (primary/secondary/tertiary) is ever logged — never the key value.
MISTRAL_API_KEY_PRIMARY=your_primary_mistral_api_key_here
MISTRAL_API_KEY_SECONDARY=your_secondary_mistral_api_key_here
MISTRAL_API_KEY_TERTIARY=your_tertiary_mistral_api_key_here

# Rate Limit Wait & Retry Configuration
# When all API keys (PRIMARY, SECONDARY, TERTIARY) are exhausted due to 429 rate-limit errors,
# the system can wait and retry automatically instead of raising an error immediately.
# ENABLE_RATE_LIMIT_WAIT: Set to true to enable wait-and-retry behavior (default: true)
# RATE_LIMIT_WAIT_SECONDS: Seconds to wait when all keys are exhausted (default: 60)
# MAX_RETRY_ATTEMPTS: Maximum number of retry cycles after exhaustion (default: 1000)
ENABLE_RATE_LIMIT_WAIT=true
RATE_LIMIT_WAIT_SECONDS=60
MAX_RETRY_ATTEMPTS=1000

OLLAMA_BASE_URL=http://localhost:11434/v1/

# Custom OpenAI-compatible endpoint
LLM_BASE_URL=
LLM_API_KEY=
LLM_VERIFY_SSL=true
LLM_DISABLE_TRACING=true

# Exa MCP HTTP endpoint (tool-scoped URL; no direct Exa API key needed here)
EXA_MCP_HTTP_URL=https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check
EXA_HTTP_TIMEOUT_SECONDS=25
EXA_DEEP_RESEARCH_TIMEOUT_SECONDS=120
EXA_DEEP_RESEARCH_POLL_INTERVAL_SECONDS=6
